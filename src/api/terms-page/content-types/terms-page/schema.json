      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "contact_label": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "contact_address": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "contact_email": {
