{
  "kind": "collectionType",
  "collectionName": "pam_modules",
  "info": {
    "singularName": "pam-module",
    "pluralName": "pam-modules",
    "displayName": "PAM Module",
    "description": "Postacademic Module – listing card and detail page content"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "date": {
      "type": "string",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "location": {
      "type": "string",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "imageOverlay": {
      "type": "string",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "badges": {
      "type": "json",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "badge": {
      "type": "string",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "is_past": {
      "type": "boolean",
      "default": false
