    "src": {
      "type": "text",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "tab_content": {
      "type": "string",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "tab_lecturers": {
      "type": "string",
